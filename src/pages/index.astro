---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebSite',
			name: SITE_TITLE,
			url: 'https://blog.everscode.com',
			description: SITE_DESCRIPTION,
		},
		{
			'@type': 'Person',
			name: 'Ever Garcia',
			url: 'https://blog.everscode.com',
			jobTitle: 'Full Stack Developer',
			sameAs: [
				'https://github.com/urielcookies',
				'https://linkedin.com/in/uriel621',
			],
		},
	],
};

const services = [
	{
		title: 'Web Development',
		desc: 'React, Vue, Django, and more. From landing pages to full-stack apps.',
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
	},
	{
		title: 'Mobile Apps',
		desc: 'Cross-platform iOS & Android with React Native. One codebase, two stores.',
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
	},
	{
		title: 'UI/UX Design',
		desc: 'Clean, accessible interfaces that feel good to use, not just look good.',
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>`,
	},
	{
		title: 'API Integration',
		desc: 'RESTful, GraphQL, webhooks, third-party services. Wired up cleanly.',
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>`,
	},
	{
		title: 'Maintenance & Support',
		desc: 'Bug fixes, refactors, performance work. Keeping existing systems healthy.',
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
	},
	{
		title: 'Cloud Deployment',
		desc: 'AWS, Azure, GCP. CI/CD pipelines, infra setup, and environment management.',
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>`,
	},
];

const stack = ['React', 'TypeScript', 'Django', 'React Native', 'AWS', 'PostgreSQL'];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} jsonLd={jsonLd} />
	</head>
	<body>
		<Header />
		<main>

			<!-- ── HERO ─────────────────────────────────────────── -->
			<section id="intro" class="section hero-section">
				<div class="hero-glow-1" aria-hidden="true"></div>
				<div class="hero-glow-2" aria-hidden="true"></div>

				<p class="greeting">Hey, I'm</p>
				<h1 class="hero-name">Ever</h1>
				<p class="role">Full Stack Developer &amp; Occasional Blogger</p>
				<p class="bio">
					I spend most of my days building web and mobile applications. React, TypeScript,
					Django, React Native, whatever the problem calls for. After hours I'm usually
					chipping away at a side project or writing about something I ran into along the way.
				</p>

				<div class="stack-pills">
					{stack.map((tech) => <span class="pill">{tech}</span>)}
				</div>

				<div class="hero-ctas">
					<a href="#contact" class="btn-primary">Get in Touch</a>
					<a href="/EversResume2025.pdf" target="_blank" rel="noopener noreferrer" class="btn-secondary">
						Resume
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
					</a>
				</div>
			</section>

			<!-- ── SERVICES ──────────────────────────────────────── -->
			<section id="services" class="section">
				<p class="section-label">// Services</p>
				<h2 class="section-title">What I Build</h2>
				<p class="section-desc">
					I take on work across the full stack, from initial scoping to production deploy.
					Whether you're starting from scratch or need an extra pair of hands, reach out.
				</p>
				<div class="services-grid">
					{services.map((s) => (
						<div class="service-card">
							<div class="service-icon" set:html={s.icon} />
							<h3 class="service-title">{s.title}</h3>
							<p class="service-desc">{s.desc}</p>
						</div>
					))}
				</div>
			</section>

			<!-- ── RECENT POSTS ───────────────────────────────────── -->
			{posts.length > 0 && (
				<section id="blog" class="section">
					<p class="section-label">// Writing</p>
					<h2 class="section-title">Recent Posts</h2>
					<div class="post-list">
						{posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="post-card-body">
									<span class="post-title">{post.data.title}</span>
									<p class="post-desc">{post.data.description}</p>
								</div>
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						))}
					</div>
					<a href="/blog" class="all-posts-link">
						All posts
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</a>
				</section>
			)}

			<!-- ── CONTACT ────────────────────────────────────────── -->
			<section id="contact" class="section contact-section">
				<p class="section-label">// Contact</p>
				<h2 class="section-title">Let's Work Together</h2>
				<p class="section-desc">
					Open to freelance projects, consulting, and interesting collaborations.
					The best way to reach me is email.
				</p>
				<div class="contact-grid">
					<a href="https://github.com/urielcookies" target="_blank" rel="noopener noreferrer" class="contact-card">
						<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						<span class="contact-label">GitHub</span>
						<span class="contact-value">urielcookies</span>
					</a>
					<a href="https://linkedin.com/in/uriel621" target="_blank" rel="noopener noreferrer" class="contact-card">
						<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						<span class="contact-label">LinkedIn</span>
						<span class="contact-value">uriel621</span>
					</a>
					<a href="mailto:evergarcia621@outlook.com" class="contact-card">
						<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M20 4H4c-1.103 0-2 .897-2 2v12c0 1.103.897 2 2 2h16c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2zm0 2v.511l-8 6.223-8-6.222V6h16zM4 18V9.044l7.386 5.745a.994.994 0 001.228 0L20 9.044 20.002 18H4z"/></svg>
						<span class="contact-label">Email</span>
						<span class="contact-value">evergarcia621@outlook.com</span>
					</a>
					<a href="tel:+15054001198" class="contact-card">
						<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
						<span class="contact-label">Phone</span>
						<span class="contact-value">+1 (505) 400-1198</span>
					</a>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: var(--container-wide, 960px);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 0 1rem;
	}

	.section {
		padding: 5rem 0;
		border-bottom: 1px solid var(--c-border-subtle);
	}

	.section:last-child {
		border-bottom: none;
	}

	/* ── Section labels ── */
	.section-label {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		background: var(--gradient-brand);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin: 0 0 0.5rem 0;
	}

	.section-title {
		font-size: 1.953rem;
		font-weight: 800;
		color: var(--c-heading);
		letter-spacing: -0.03em;
		margin: 0 0 0.75rem 0;
	}

	.section-desc {
		color: var(--c-text-2);
		max-width: 560px;
		margin: 0 0 2.5rem 0;
		line-height: 1.7;
		font-size: 0.95rem;
	}

	/* ── HERO ── */
	.hero-section {
		padding-top: 6rem;
		padding-bottom: 6rem;
		position: relative;
	}

	.hero-glow-1 {
		position: absolute;
		width: 700px;
		height: 700px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(168, 85, 247, 0.13) 0%, transparent 70%);
		top: -200px;
		left: -350px;
		pointer-events: none;
	}

	.hero-glow-2 {
		position: absolute;
		width: 500px;
		height: 500px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
		top: 60px;
		left: 280px;
		pointer-events: none;
	}

	.greeting {
		font-size: 1rem;
		color: var(--c-text-3);
		font-weight: 500;
		margin: 0 0 0.25rem 0;
		position: relative;
	}

	.hero-name {
		font-size: clamp(3.5rem, 10vw, 6rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
		margin: 0 0 0.4rem 0;
		background: var(--gradient-brand);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		position: relative;
	}

	.role {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--c-text);
		margin: 0 0 1.25rem 0;
		position: relative;
	}

	.bio {
		font-size: 0.95rem;
		color: var(--c-text-2);
		max-width: 540px;
		line-height: 1.75;
		margin: 0 0 1.75rem 0;
		position: relative;
	}

	/* Tech stack pills */
	.stack-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2.25rem;
		position: relative;
	}

	.pill {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--c-text-3);
		background: var(--c-bg-elevated);
		border: 1px solid var(--c-border);
		padding: 0.25rem 0.7rem;
		border-radius: 9999px;
		letter-spacing: 0.01em;
	}

	/* CTA buttons */
	.hero-ctas {
		display: flex;
		gap: 0.875rem;
		flex-wrap: wrap;
		position: relative;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.7rem 1.6rem;
		background: var(--gradient-brand);
		color: #ffffff;
		font-weight: 700;
		font-size: 0.9rem;
		border-radius: 8px;
		text-decoration: none;
		transition: transform 150ms ease, box-shadow 150ms ease, opacity 150ms ease;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(168, 85, 247, 0.35);
		opacity: 0.92;
		color: #ffffff;
	}

	.btn-primary:active {
		transform: translateY(0);
	}

	.btn-secondary {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.7rem 1.6rem;
		background:
			linear-gradient(var(--c-bg), var(--c-bg)) padding-box,
			var(--gradient-brand) border-box;
		border: 1.5px solid transparent;
		color: #a855f7;
		font-weight: 700;
		font-size: 0.9rem;
		border-radius: 8px;
		text-decoration: none;
		transition: transform 150ms ease, box-shadow 150ms ease;
	}

	.btn-secondary:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 18px rgba(168, 85, 247, 0.2);
		color: #c084fc;
	}

	.btn-secondary:active {
		transform: translateY(0);
	}

	/* ── SERVICES ── */
	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.service-card {
		background: var(--c-bg-elevated);
		border: 1px solid var(--c-border);
		border-radius: 12px;
		padding: 1.5rem;
		transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
	}

	.service-card:hover {
		border-color: rgba(168, 85, 247, 0.4);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(168, 85, 247, 0.08);
	}

	.service-icon {
		width: 40px;
		height: 40px;
		border-radius: 10px;
		background: rgba(168, 85, 247, 0.1);
		border: 1px solid rgba(168, 85, 247, 0.2);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #a855f7;
		margin-bottom: 1rem;
	}

	.service-title {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--c-heading);
		margin: 0 0 0.4rem 0;
		letter-spacing: -0.01em;
	}

	.service-desc {
		font-size: 0.82rem;
		color: var(--c-text-3);
		line-height: 1.6;
		margin: 0;
	}

	/* ── RECENT POSTS ── */
	.post-list {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
		margin-bottom: 1.75rem;
	}

	.post-card {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2rem;
		padding: 1.25rem 1.5rem;
		background: var(--c-bg-elevated);
		border: 1px solid var(--c-border);
		border-radius: 12px;
		text-decoration: none;
		transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
	}

	.post-card:hover {
		border-color: rgba(168, 85, 247, 0.4);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(168, 85, 247, 0.08);
	}

	.post-card:hover .post-title {
		color: #c084fc;
	}

	.post-card-body {
		flex: 1;
		min-width: 0;
	}

	.post-title {
		display: block;
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--c-heading);
		margin-bottom: 0.35rem;
		transition: color 150ms ease;
	}

	.post-desc {
		font-size: 0.82rem;
		color: var(--c-text-3);
		line-height: 1.55;
		margin: 0;
	}

	.post-date {
		font-size: 0.75rem;
		color: var(--c-text-4);
		white-space: nowrap;
		font-weight: 500;
		padding-top: 0.15rem;
		flex-shrink: 0;
	}

	.all-posts-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.875rem;
		font-weight: 700;
		color: #a855f7;
		text-decoration: none;
		transition: gap 150ms ease, color 150ms ease;
	}

	.all-posts-link:hover {
		gap: 0.6rem;
		color: #c084fc;
	}

	/* ── CONTACT ── */
	.contact-section {
		border-bottom: none;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.75rem;
	}

	.contact-card {
		display: flex;
		align-items: center;
		gap: 0.875rem;
		padding: 1rem 1.25rem;
		background: var(--c-bg-elevated);
		border: 1px solid var(--c-border);
		border-radius: 12px;
		text-decoration: none;
		transition: border-color 200ms ease, transform 200ms ease;
	}

	.contact-card:hover {
		border-color: rgba(168, 85, 247, 0.4);
		transform: translateY(-2px);
	}

	.contact-card svg {
		color: #a855f7;
		flex-shrink: 0;
	}

	.contact-card:hover svg {
		color: #c084fc;
	}

	.contact-label {
		display: block;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--c-text-4);
	}

	.contact-value {
		display: block;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--c-text);
		transition: color 150ms ease;
	}

	.contact-card:hover .contact-value {
		color: #c084fc;
	}

	/* ── RESPONSIVE ── */
	@media (max-width: 720px) {
		.section {
			padding: 3.5rem 0;
		}

		.hero-section {
			padding-top: 3.5rem;
			padding-bottom: 3.5rem;
		}

		.services-grid {
			grid-template-columns: 1fr;
		}

		.contact-grid {
			grid-template-columns: 1fr;
		}

		.post-card {
			flex-direction: column;
			gap: 0.5rem;
		}

		.hero-glow-1,
		.hero-glow-2 {
			display: none;
		}
	}

	@media (min-width: 721px) and (max-width: 900px) {
		.services-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
