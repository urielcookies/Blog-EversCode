			</div>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		margin: 0;
		padding: 0 1.5rem;
		background: var(--glass-bg);
		backdrop-filter: var(--glass-blur);
		-webkit-backdrop-filter: var(--glass-blur);
		border-bottom: 1px solid var(--glass-border);
		transition: background-color 250ms ease, border-color 250ms ease;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
		max-width: var(--container-dashboard, 1280px);
		margin: 0 auto;
	}

	/* Brand name */
	h2 {
		margin: 0;
		font-size: 1.05rem;
		font-weight: 800;
		letter-spacing: -0.03em;
		flex-shrink: 0;
	}

	.brand {
		background: linear-gradient(135deg, #c084fc 0%, #60a5fa 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		text-decoration: none;
		transition: opacity 150ms ease;
	}

	.brand:hover {
		opacity: 0.8;
	}

	/* Internal nav links */
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.125rem;
	}

	nav :global(a) {
		position: relative;
		padding: 0.375rem 0.75rem;
		color: var(--c-text-3);
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none;
		border-radius: 6px;
		transition: color 150ms ease, background-color 150ms ease;
	}

	nav :global(a:hover) {
		color: var(--c-text);
		background-color: rgba(128, 128, 128, 0.08);
	}

	nav :global(a.active) {
		color: var(--c-heading);
		background-color: rgba(168, 85, 247, 0.1);
	}

	nav :global(a.active)::after {
		content: '';
		position: absolute;
		bottom: -1px;
		left: 50%;
		transform: translateX(-50%);
		width: 60%;
		height: 2px;
		background: linear-gradient(90deg, #a855f7, #3b82f6);
		border-radius: 9999px;
	}

	/* Right-side actions: toggle + socials */
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	/* Theme toggle button */
	#theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 8px;
		border: none;
		background: transparent;
		color: var(--c-text-3);
		cursor: pointer;
		transition: color 200ms ease, background-color 200ms ease;
		flex-shrink: 0;
	}

	#theme-toggle:hover {
		color: var(--c-text);
		background-color: rgba(128, 128, 128, 0.08);
	}

	#theme-toggle svg {
		display: block;
		transition: transform 300ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	#theme-toggle:hover svg {
		transform: rotate(20deg) scale(1.1);
	}

	/* Social icons */
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.125rem;
	}

	.social-link {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 8px;
		color: var(--c-text-4);
		text-decoration: none;
		transition: color 200ms ease, background-color 200ms ease;
	}

	.social-link svg {
		display: block;
		transition: transform 200ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.social-link:hover {
		color: #c084fc;
		background-color: rgba(168, 85, 247, 0.1);
	}

	.social-link:hover svg {
		transform: scale(1.15);
	}

	/* Tooltip — drops below since header is pinned to top of viewport */
	.social-link[data-tooltip]::before {
		content: attr(data-tooltip);
		position: absolute;
		top: calc(100% + 8px);
		left: 50%;
		transform: translateX(-50%) translateY(-4px);
		background: var(--c-bg-elevated);
		color: var(--c-text);
		font-size: 0.72rem;
		font-weight: 500;
		padding: 0.3rem 0.6rem;
		border-radius: 6px;
		border: 1px solid var(--c-border);
		white-space: nowrap;
		pointer-events: none;
		opacity: 0;
		transition: opacity 150ms ease, transform 150ms ease;
		z-index: 100;
	}

	.social-link[data-tooltip]:hover::before {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}

	@media (max-width: 720px) {
		header {
			padding: 0 1rem;
		}

		nav {
			height: 56px;
		}

		.social-links {
			display: none;
		}
	}
</style>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    const html = document.documentElement;

    function syncIcons() {
      const isLight = html.dataset.theme === 'light';
      const sun = btn?.querySelector('.icon-sun') as HTMLElement | null;
      const moon = btn?.querySelector('.icon-moon') as HTMLElement | null;
      if (sun)  sun.style.display  = isLight ? 'none'  : 'block';
      if (moon) moon.style.display = isLight ? 'block' : 'none';
    }

    syncIcons();

    btn?.addEventListener('click', () => {
      const newTheme = html.dataset.theme === 'light' ? 'dark' : 'light';
      html.dataset.theme = newTheme;
      localStorage.setItem('theme', newTheme);
      syncIcons();
    });
  }

  // Runs on initial load and after every Astro view transition
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
